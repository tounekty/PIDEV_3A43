<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="550.0" spacing="15.0" style="-fx-padding: 20; -fx-font-family: 'Segoe UI'; -fx-background-color: #f9fbff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <!-- EN-TÊTE -->
    <VBox spacing="5.0">
        <children>
            <Label text="🎟️ Ajouter une Réservation Avancée" style="-fx-font-weight: bold; -fx-font-size: 20;" textFill="#1976D2" />
            <Label text="Utilisez le calendrier avancé pour réserver une place" style="-fx-font-size: 12; -fx-text-fill: #666;" />
        </children>
    </VBox>

    <!-- FORMULAIRE -->
    <VBox spacing="12.0" VBox.vgrow="ALWAYS" style="-fx-padding: 15; -fx-background-color: white; -fx-border-radius: 12; -fx-border-color: #e0e0e0;">
        <!-- CALENDRIER AVANCÉ -->
        <VBox spacing="8.0" style="-fx-border-color: #d7e7ff; -fx-border-radius: 8; -fx-background-color: #f9fbff; -fx-padding: 15;">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="📅 Étape 1: Sélectionnez une date" textFill="#1976D2" />
                <Label style="-fx-font-size: 11; -fx-text-fill: #666; -fx-wrap-text: true;" 
                       text="🟠 Orange: Peu de places (1-25%) | 🔵 Cyan: Beaucoup de places (25-99%) | ⚫ Gris: Complet (0%) | 🟢 Vert: Disponible (100%)" />
                <Region VBox.vgrow="ALWAYS" />
                <!-- Le calendrier avancé sera inséré ici par le code Java -->
            </children>
        </VBox>

        <Separator />

        <!-- Sélection de l'événement -->
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 12;" text="Étape 2: Sélectionnez un événement *" />
                <ComboBox fx:id="eventComboBox" promptText="Choisir un événement..." style="-fx-font-size: 12; -fx-padding: 8; -fx-min-height: 35;" />
                <Label style="-fx-font-size: 10; -fx-text-fill: #999;" text="Les événements avec places disponibles sont affichés" />
            </children>
        </VBox>

        <!-- Informations de l'événement sélectionné -->
        <VBox spacing="10.0" style="-fx-border-color: #E0E0E0; -fx-border-radius: 5; -fx-padding: 12; -fx-background-color: #F5F5F5;">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 12;" text="Détails de l'événement" />
                
                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 10; -fx-text-fill: #666;" text="Date / Heure" />
                                <Label fx:id="eventDateLabel" style="-fx-font-weight: bold; -fx-font-size: 12;" text="Non sélectionné" />
                            </children>
                        </VBox>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 10; -fx-text-fill: #666;" text="Lieu" />
                                <Label fx:id="eventLocationLabel" style="-fx-font-weight: bold; -fx-font-size: 12;" text="Non sélectionné" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 10; -fx-text-fill: #666;" text="Capacité totale" />
                                <Label fx:id="eventCapacityLabel" style="-fx-font-weight: bold; -fx-font-size: 12;" text="0 places" />
                            </children>
                        </VBox>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-size: 10; -fx-text-fill: #666;" text="Places disponibles" />
                                <Label fx:id="eventAvailableLabel" style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #4CAF50;" text="0 places" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Sélection de l'utilisateur -->
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-weight: bold;" text="Étape 3: Sélectionnez un utilisateur *" />
                <ComboBox fx:id="userComboBox" promptText="Choisir un utilisateur..." style="-fx-font-size: 12; -fx-padding: 8; -fx-min-height: 35;" />
            </children>
        </VBox>

        <!-- Nombre de places -->
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-weight: bold;" text="Nombre de places" />
                <Spinner fx:id="quantitySpinner" editable="true" prefWidth="500.0" style="-fx-font-size: 12;" />
            </children>
        </VBox>

        <!-- Avertissements -->
        <VBox style="-fx-border-color: #E3F2FD; -fx-border-radius: 3; -fx-background-color: #F0F8FF; -fx-padding: 10;">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #1565C0;" text="ℹ️ Information importante" />
                <Label style="-fx-font-size: 10; -fx-text-fill: #1565C0; -fx-wrap-text: true;" 
                       text="Une fois confirmée, la réservation ne peut être annulée que par l'administrateur. Vérifiez bien la date et l'événement avant de confirmer." />
            </children>
        </VBox>
    </VBox>

    <!-- BOUTONS D'ACTION -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <children>
            <Button style="-fx-background-color: white; -fx-text-fill: #666; -fx-border-color: #ccc; -fx-padding: 10 20 10 20; -fx-background-radius: 8;" text="Annuler" />
            <Button style="-fx-background-color: linear-gradient(to right,#0f69ff,#38a4ff); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 8;" text="✓ Confirmer la réservation" />
        </children>
    </HBox>
</VBox>
