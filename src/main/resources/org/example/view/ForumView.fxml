<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8" />
    </padding>
    <children>
        <ScrollPane fitToWidth="true" pannable="true" hbarPolicy="NEVER" style="-fx-background-color:transparent; -fx-background:transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="16" style="-fx-background-color: rgba(255,255,255,0.96); -fx-background-radius: 24; -fx-border-radius: 24; -fx-border-color: rgba(120,169,230,0.20); -fx-effect: dropshadow(gaussian, rgba(46,94,166,0.12), 24, 0.18, 0, 8);">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28" />
                    </padding>
                    <children>
                        <Label fx:id="forumTitle" text="Forum" style="-fx-text-fill:#10233f; -fx-font-size:24px; -fx-font-weight:800;" />
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <TextField fx:id="forumSearchField" promptText="Recherche par titre, categorie, statut..." style="-fx-background-color: #f9fbff; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d7e7ff; -fx-padding: 12 14 12 14;" />
                            <ComboBox fx:id="forumSortField" style="-fx-background-color: #f9fbff; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d7e7ff; -fx-padding: 6 10 6 10;" />
                            <Button text="Effacer" onAction="#handleClearForumSearch" style="-fx-background-color: white; -fx-text-fill: #1c4f96; -fx-font-weight: 700; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cfe3ff; -fx-padding: 11 16 11 16;" />
                            <Button text="Nouveau sujet" onAction="#handleNewSubject" style="-fx-background-color: linear-gradient(to right,#0f69ff,#38a4ff); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 14; -fx-padding: 12 18 12 18;" />
                            <Button text="Actualiser" onAction="#handleRefreshForum" style="-fx-background-color: white; -fx-text-fill: #1c4f96; -fx-font-weight: 700; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cfe3ff; -fx-padding: 11 16 11 16;" />
                        </HBox>
                        <ListView fx:id="forumListView" style="-fx-background-color:transparent; -fx-control-inner-background:transparent; -fx-padding:6;" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
