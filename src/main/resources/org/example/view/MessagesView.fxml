<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8" />
    </padding>
    <children>
        <ScrollPane fitToWidth="true" pannable="true" hbarPolicy="NEVER" style="-fx-background-color:transparent; -fx-background:transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="16" style="-fx-background-color: rgba(255,255,255,0.96); -fx-background-radius: 24; -fx-border-radius: 24; -fx-border-color: rgba(120,169,230,0.20); -fx-effect: dropshadow(gaussian, rgba(46,94,166,0.12), 24, 0.18, 0, 8);">
                    <padding>
                        <Insets top="28" right="28" bottom="28" left="28" />
                    </padding>
                    <children>
                        <Label fx:id="messagesTitle" text="Commentaires" style="-fx-text-fill:#10233f; -fx-font-size:24px; -fx-font-weight:800;" />
                        <Label text="Discussion sur le sujet selectionne." style="-fx-text-fill:#637a97; -fx-font-size:13px;" />
                        <Label text="Affichage en fil: les reponses sont indentees sous leur commentaire parent (max 3 niveaux)." style="-fx-text-fill:#5a7291; -fx-font-size:12px; -fx-font-weight:700;" />
                        <Label fx:id="messagesErrorLabel" text="" visible="false" managed="false" style="-fx-text-fill: #c63d48; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        <ListView fx:id="messageListView" style="-fx-background-color:transparent; -fx-control-inner-background:transparent; -fx-padding:6;" VBox.vgrow="ALWAYS" />
                        <VBox spacing="12">
                            <children>
                                <Label text="Nouveau commentaire" style="-fx-text-fill:#10233f; -fx-font-size:16px; -fx-font-weight:800;" />
                                <HBox spacing="10">
                                    <children>
                                        <Label fx:id="messageReplyInfoLabel" text="" visible="false" managed="false" style="-fx-text-fill:#2a5fa3; -fx-font-size:12px; -fx-font-weight:700;" />
                                        <Button fx:id="messageCancelReplyButton" text="Annuler la reponse" onAction="#handleMessageReplyCancel" visible="false" managed="false" style="-fx-background-color: white; -fx-text-fill: #1c4f96; -fx-font-weight: 700; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cfe3ff; -fx-padding: 8 14 8 14;" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="messageContentArea" promptText="Votre commentaire..." prefRowCount="3" style="-fx-background-color: #f9fbff; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d7e7ff; -fx-padding: 12 14 12 14;" />
                                <HBox spacing="12">
                                    <children>
                                        <Label text="anonymous" style="-fx-text-fill:#29496f; -fx-font-size:12px; -fx-font-weight:700;" />
                                        <CheckBox fx:id="messageAnonymousCheck" text="Anonyme" />
                                    </children>
                                </HBox>
                                <VBox spacing="6">
                                    <children>
                                        <HBox spacing="10">
                                            <TextField fx:id="messageAttachmentPathField" editable="false" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fbff; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #d7e7ff; -fx-padding: 12 14 12 14;" />
                                            <Button text="Joindre" onAction="#handleMessageAttachmentBrowse" style="-fx-background-color: white; -fx-text-fill: #1c4f96; -fx-font-weight: 700; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cfe3ff; -fx-padding: 11 16 11 16;" />
                                            <Button text="Effacer" onAction="#handleMessageAttachmentClear" style="-fx-background-color: white; -fx-text-fill: #1c4f96; -fx-font-weight: 700; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cfe3ff; -fx-padding: 11 16 11 16;" />
                                        </HBox>
                                        <Label fx:id="messageAttachmentMeta" text="Aucun fichier" style="-fx-text-fill:#637a97; -fx-font-size:13px;" />
                                    </children>
                                </VBox>
                                <HBox spacing="12">
                                    <children>
                                        <Button text="Publier" onAction="#handleMessageSend" style="-fx-background-color: linear-gradient(to right,#0f69ff,#38a4ff); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 14; -fx-padding: 12 18 12 18;" />
                                        <Button text="Retour au forum" onAction="#handleMessageBack" style="-fx-background-color: white; -fx-text-fill: #1c4f96; -fx-font-weight: 700; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #cfe3ff; -fx-padding: 11 16 11 16;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
