<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8" />
    </padding>
    <children>
        <ScrollPane fitToWidth="true" pannable="true" hbarPolicy="NEVER" style="-fx-background-color:transparent; -fx-background:transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="20" alignment="CENTER">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40" />
                    </padding>
                    <children>
                        <Label text="Bienvenue sur MindCare" style="-fx-text-fill:#10233f; -fx-font-size:32px; -fx-font-weight:800;" />
                        <Label text="Votre bien-etre mental, notre priorite" style="-fx-text-fill:#637a97; -fx-font-size:16px;" />

                        <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20 0 20 0;">
                            <children>
                                <VBox spacing="10" alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 20; -fx-padding: 25;">
                                    <children>
                                        <Label fx:id="homeEventsIcon" text="" style="-fx-font-size: 40px;" />
                                        <Label fx:id="homeEventsCount" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                        <Label text="Evenements" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="10" alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #f093fb, #f5576c); -fx-background-radius: 20; -fx-padding: 25;">
                                    <children>
                                        <Label fx:id="homeForumIcon" text="" style="-fx-font-size: 40px;" />
                                        <Label fx:id="homeForumCount" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                        <Label text="Discussions" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" />
                                    </children>
                                </VBox>
                                <VBox spacing="10" alignment="CENTER" style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe); -fx-background-radius: 20; -fx-padding: 25;">
                                    <children>
                                        <Label fx:id="homeReservationsIcon" text="" style="-fx-font-size: 40px;" />
                                        <Label fx:id="homeReservationsCount" text="0" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
                                        <Label text="Reservations" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label text="Actions rapides" style="-fx-text-fill:#10233f; -fx-font-size:20px; -fx-font-weight:700;" />
                        <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                            <children>
                                <Button text="Voir les evenements" onAction="#handleGoEvents" style="-fx-background-color: linear-gradient(to right,#0f69ff,#38a4ff); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 14; -fx-padding: 12 18 12 18;" />
                                <Button text="Visiter le forum" onAction="#handleGoForum" style="-fx-background-color: linear-gradient(to right,#0f69ff,#38a4ff); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 14; -fx-padding: 12 18 12 18;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
