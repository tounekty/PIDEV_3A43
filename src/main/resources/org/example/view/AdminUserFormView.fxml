<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" spacing="30" styleClass="dashboard-card" style="-fx-background-color: white; -fx-padding: 40px; -fx-background-radius: 12px; -fx-max-width: 700; -fx-alignment: top-center;">
    <stylesheets>
        <URL value="@mindcare-theme.css" />
    </stylesheets>

    <children>
        <!-- Header & Back Button -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Button fx:id="adminBackToListButton" text="← Back to Users" style="-fx-background-color: transparent; -fx-text-fill: #6b7280; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="adminUserFormTitle" text="User Details" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #111827;" />
            </VBox>
        </HBox>

        <Separator style="-fx-padding: 0 0 10px 0;" />

        <!-- Form Layout -->
        <GridPane hgap="30" vgap="25">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" />
                <ColumnConstraints percentWidth="50" />
            </columnConstraints>
            <children>
                <VBox spacing="8" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <Label text="Username" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <TextField fx:id="adminUsernameField" promptText="Enter username" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="8" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <Label text="Email Address" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <TextField fx:id="adminEmailField" promptText="name@example.com" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="0">
                    <Label text="First Name" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <TextField fx:id="adminFirstNameField" promptText="First name" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="8" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <Label text="Last Name" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <TextField fx:id="adminLastNameField" promptText="Last name" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                </VBox>

                <VBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="0">
                    <Label text="Role" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <ComboBox fx:id="adminRoleField" maxWidth="Infinity" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8px;" />
                </VBox>

                <VBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <Label text="Banned Until" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <DatePicker fx:id="adminBannedUntilField" promptText="Leave empty if active" maxWidth="Infinity" style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 8px;" />
                </VBox>

                <VBox spacing="8" GridPane.rowIndex="3" GridPane.columnSpan="2">
                    <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;" />
                    <PasswordField fx:id="adminPasswordField" promptText="Required for new users. Leave blank to keep existing." style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 12px; -fx-font-size: 14px;" />
                </VBox>
            </children>
        </GridPane>

        <Label fx:id="adminUserFormErrorLabel" visible="false" managed="false" style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #fee2e2; -fx-padding: 12px 16px; -fx-background-radius: 8px; -fx-border-color: #fecaca; -fx-border-radius: 8px;" maxWidth="Infinity" alignment="CENTER" />

        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 20px 0 0 0;">
            <Button fx:id="adminResetUserButton" text="Clear Form" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 8px; -fx-padding: 12px 24px; -fx-font-weight: bold; -fx-text-fill: #374151; -fx-cursor: hand;" />
            <Button fx:id="adminSaveUserButton" text="Save Profile" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px 32px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.4), 8, 0, 0, 4);" />
        </HBox>

    </children>
</VBox>
