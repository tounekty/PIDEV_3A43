<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.example.controller.ResourceDetailController"
    fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
    styleClass="admin-root" stylesheets="@../css/admin-theme.css">
    <content>
    <VBox spacing="16" styleClass="detail-page">
        <padding>
            <Insets top="22" right="24" bottom="24" left="24"/>
        </padding>

    <!-- En-tête ressource -->
    <VBox spacing="12" styleClass="detail-hero">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="typeLabel" styleClass="resource-pill"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="createdAtLabel" styleClass="meta-text"/>
        </HBox>
        <Label fx:id="titleLabel" wrapText="true" styleClass="detail-title"/>
        <Label text="Consultation de la ressource et gestion des commentaires" styleClass="admin-subtitle"/>
    </VBox>
    
    <!-- Description -->
    <VBox spacing="12" styleClass="description-panel">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Description" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="ttsPlayBtn" text="🔊 Lire" onAction="#handlePlayDescription" styleClass="btn-secondary"/>
            <ComboBox fx:id="ttsVoiceCombo" prefWidth="140" promptText="Voix" styleClass="admin-input"/>
            <ComboBox fx:id="ttsSpeedCombo" prefWidth="120" promptText="Vitesse" styleClass="admin-input"/>
            <ComboBox fx:id="translationDescLangCombo" prefWidth="170" promptText="Sélectionner langue" styleClass="admin-input"/>
            <Button fx:id="translateDescBtn" text="Traduire" onAction="#handleTranslateDescription" styleClass="btn-secondary"/>
        </HBox>
        <TextArea fx:id="descriptionArea" wrapText="true" prefHeight="180" minHeight="150" VBox.vgrow="ALWAYS" styleClass="description-area"/>
    </VBox>

    <!-- Visuel article -->
    <VBox fx:id="imageSection" spacing="0">
        <StackPane prefHeight="230" styleClass="media-card">
            <ImageView fx:id="resourceImageView" fitHeight="210" fitWidth="760" preserveRatio="true" smooth="true"/>
            <Label fx:id="imageErrorLabel" text="" styleClass="meta-text" visible="false" managed="false"/>
        </StackPane>
    </VBox>
    
    <!-- Vidéo -->
    <VBox fx:id="videoSection" spacing="8">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Vidéo" styleClass="section-title"/>
            <Button fx:id="openVideoBtn" text="Ouvrir sur YouTube" onAction="#handleOpenVideo"
                    styleClass="btn-secondary"/>
        </HBox>
        <StackPane styleClass="media-card">
            <WebView fx:id="videoWebView" prefHeight="320"/>
        </StackPane>
    </VBox>
    
    <!-- Separator -->
    <Separator/>
    
    <!-- Commentaires -->
    <VBox spacing="12" styleClass="comments-panel">
        <Label text="Commentaires" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchCommentField" promptText="Rechercher commentaire (auteur, contenu)" HBox.hgrow="ALWAYS" styleClass="admin-input"/>
            <ComboBox fx:id="statusFilterCombo" prefWidth="160" styleClass="admin-input"/>
            <ComboBox fx:id="ratingFilterCombo" prefWidth="170" styleClass="admin-input"/>
            <ComboBox fx:id="sortCommentCombo" prefWidth="220" styleClass="admin-input"/>
        </HBox>
        
        <!-- Traduction commentaires -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Traduire en:" styleClass="field-label"/>
            <ComboBox fx:id="translationLangCombo" prefWidth="150" promptText="Sélectionner langue" styleClass="admin-input"/>
            <Button fx:id="translateCommentBtn" text="Traduire commentaires" onAction="#handleTranslateComments" styleClass="btn-secondary"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
        
        <ListView fx:id="commentaireListView" prefHeight="220" VBox.vgrow="ALWAYS" styleClass="admin-list"/>
        
        <!-- Boutons d'action commentaires -->
        <HBox spacing="10" styleClass="actions-row">
            <Button fx:id="addCommentBtn" text="Ajouter" onAction="#handleAddComment" styleClass="btn-success"/>
            <Button fx:id="approveCommentBtn" text="Approuver" onAction="#handleApproveComment" styleClass="btn-primary"/>
            <Button fx:id="deleteCommentBtn" text="Supprimer" onAction="#handleDeleteComment" styleClass="btn-danger"/>
        </HBox>
    </VBox>
    </VBox>
    </content>
</ScrollPane>
