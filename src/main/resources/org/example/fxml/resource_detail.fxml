<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.example.controller.ResourceDetailController" spacing="12" styleClass="admin-root"
    stylesheets="@../css/admin-theme.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="4">
        <Label text="Détail Ressource" styleClass="admin-title"/>
        <Label text="Consultation complète et gestion des commentaires" styleClass="admin-subtitle"/>
    </VBox>
    
    <!-- En-tête ressource -->
    <VBox spacing="8" styleClass="admin-card">
        <HBox spacing="15">
            <Label text="Titre:" styleClass="field-label"/>
            <Label fx:id="titleLabel" styleClass="value-title"/>
        </HBox>
        <HBox spacing="15">
            <Label text="Type:" styleClass="field-label"/>
            <Label fx:id="typeLabel" styleClass="value-text"/>
        </HBox>
        <Label fx:id="createdAtLabel" styleClass="meta-text"/>
    </VBox>
    
    <!-- Description -->
    <Label text="Description" styleClass="field-label"/>
    <TextArea fx:id="descriptionArea" wrapText="true" prefHeight="90" styleClass="admin-input"/>

    <!-- Image (articles) -->
    <VBox fx:id="imageSection" spacing="8">
        <Label text="Image" styleClass="field-label"/>
        <StackPane prefHeight="360" styleClass="media-card">
            <ImageView fx:id="resourceImageView" fitHeight="340" fitWidth="880" preserveRatio="true" smooth="true"/>
            <Label fx:id="imageErrorLabel" text="" styleClass="meta-text" visible="false" managed="false"/>
        </StackPane>
    </VBox>
    
    <!-- Vidéo -->
    <VBox fx:id="videoSection" spacing="8">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Vidéo" styleClass="field-label"/>
            <Button fx:id="openVideoBtn" text="Ouvrir sur YouTube" onAction="#handleOpenVideo"
                    styleClass="btn-secondary"/>
        </HBox>
        <StackPane styleClass="media-card">
            <WebView fx:id="videoWebView" prefHeight="420"/>
        </StackPane>
    </VBox>
    
    <!-- Separator -->
    <Separator/>
    
    <!-- Commentaires -->
    <Label text="Commentaires" styleClass="field-label"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchCommentField" promptText="Rechercher commentaire (auteur, contenu)" HBox.hgrow="ALWAYS" styleClass="admin-input"/>
        <ComboBox fx:id="statusFilterCombo" prefWidth="160" styleClass="admin-input"/>
        <ComboBox fx:id="ratingFilterCombo" prefWidth="170" styleClass="admin-input"/>
        <ComboBox fx:id="sortCommentCombo" prefWidth="220" styleClass="admin-input"/>
        <Button fx:id="exportCommentBtn" text="Exporter CSV" onAction="#handleExportComments" styleClass="btn-secondary"/>
        <Button text="Exporter PDF" onAction="#handleExportCommentsPdf" styleClass="btn-secondary"/>
    </HBox>
    <HBox spacing="10" styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-primary">
            <Label fx:id="commentTotalValueLabel" text="0" styleClass="stat-value"/>
            <Label text="Total" styleClass="stat-caption"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-warning">
            <Label fx:id="commentAverageValueLabel" text="0.00" styleClass="stat-value"/>
            <Label text="Moyenne / 5" styleClass="stat-caption"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-success">
            <Label fx:id="commentApprovedValueLabel" text="0" styleClass="stat-value"/>
            <Label text="Approuves" styleClass="stat-caption"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-danger">
            <Label fx:id="commentPendingValueLabel" text="0" styleClass="stat-value"/>
            <Label text="En attente" styleClass="stat-caption"/>
        </VBox>
    </HBox>
    <StackPane styleClass="table-card" prefHeight="220">
        <PieChart fx:id="commentPieChart" legendVisible="true" labelsVisible="true"/>
    </StackPane>
    <ListView fx:id="commentaireListView" VBox.vgrow="ALWAYS" styleClass="admin-list"/>
    
    <!-- Boutons d'action commentaires -->
    <HBox spacing="10" styleClass="actions-row">
        <Button fx:id="addCommentBtn" text="Ajouter" onAction="#handleAddComment" styleClass="btn-success"/>
        <Button fx:id="approveCommentBtn" text="Approuver" onAction="#handleApproveComment" styleClass="btn-primary"/>
        <Button fx:id="deleteCommentBtn" text="Supprimer" onAction="#handleDeleteComment" styleClass="btn-danger"/>
    </HBox>
</VBox>
