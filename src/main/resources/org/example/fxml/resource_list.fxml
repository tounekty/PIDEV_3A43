<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.example.controller.ResourceListController" spacing="14" styleClass="admin-root"
    stylesheets="@../css/admin-theme.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="4">
        <Label text="Back Office Ressources" styleClass="admin-title"/>
        <Label text="Gestion moderne des ressources et commentaires" styleClass="admin-subtitle"/>
    </VBox>

    <!-- Barre de recherche -->
    <HBox spacing="10" styleClass="admin-search-bar" alignment="CENTER_LEFT">
        <Label text="Rechercher" styleClass="field-label"/>
        <TextField fx:id="searchField" promptText="Titre ou description..." HBox.hgrow="ALWAYS" styleClass="admin-input"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filtre" styleClass="field-label"/>
        <ComboBox fx:id="typeFilterCombo" prefWidth="170" styleClass="admin-input"/>
        <Label text="Tri" styleClass="field-label"/>
        <ComboBox fx:id="sortCombo" prefWidth="220" styleClass="admin-input"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="exportResourcesBtn" text="Exporter Ressources" onAction="#handleExportResources" styleClass="btn-secondary"/>
        <Button text="PDF Ressources" onAction="#handleExportResourcesPdf" styleClass="btn-secondary"/>
        <Button fx:id="exportCommentsBtn" text="Exporter Commentaires" onAction="#handleExportComments" styleClass="btn-secondary"/>
        <Button text="PDF Commentaires" onAction="#handleExportCommentsPdf" styleClass="btn-secondary"/>
    </HBox>

    <HBox spacing="10" styleClass="stats-row">
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-primary">
            <Label fx:id="totalValueLabel" text="0" styleClass="stat-value"/>
            <Label text="Total ressources" styleClass="stat-caption"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-success">
            <Label fx:id="articleValueLabel" text="0" styleClass="stat-value"/>
            <Label text="Articles" styleClass="stat-caption"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-warning">
            <Label fx:id="videoValueLabel" text="0" styleClass="stat-value"/>
            <Label text="Videos" styleClass="stat-caption"/>
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card stat-card-danger">
            <Label fx:id="commentValueLabel" text="0" styleClass="stat-value"/>
            <Label text="Commentaires" styleClass="stat-caption"/>
        </VBox>
    </HBox>

    <StackPane styleClass="table-card" prefHeight="220">
        <PieChart fx:id="resourcePieChart" legendVisible="true" labelsVisible="true"/>
    </StackPane>

    <!-- Tableau -->
    <StackPane styleClass="table-card" VBox.vgrow="ALWAYS">
    <TableView fx:id="resourceTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
        <columns>
            <TableColumn fx:id="titleColumn" text="Titre" prefWidth="300"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="80"/>
        </columns>
    </TableView>
    </StackPane>

    <!-- Boutons d'action -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="actions-row">
        <Button fx:id="newResourceBtn" text="Nouveau" onAction="#handleNewResource" styleClass="btn-success"/>
        <Button fx:id="viewBtn" text="Consulter" onAction="#handleViewResource" styleClass="btn-primary"/>
        <Button fx:id="editBtn" text="Modifier" onAction="#handleEditResource" styleClass="btn-warning"/>
        <Button fx:id="deleteBtn" text="Supprimer" onAction="#handleDeleteResource" styleClass="btn-danger"/>
    </HBox>
</VBox>
