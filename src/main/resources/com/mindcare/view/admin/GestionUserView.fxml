<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindcare.controller.admin.GestionUserController">
    <styleClass>
        <String fx:value="scroll-pane"/>
    </styleClass>
    <content>
        <VBox spacing="20.0">
            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
            </padding>

            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label text="Gestion User">
                            <styleClass>
                                <String fx:value="page-title"/>
                            </styleClass>
                        </Label>
                        <Label text="Manage all registered users on the platform">
                            <styleClass>
                                <String fx:value="page-subtitle"/>
                            </styleClass>
                        </Label>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <styleClass>
                        <String fx:value="filter-bar"/>
                    </styleClass>
                    <children>
                        <TextField fx:id="searchField" promptText="Search by name or email...">
                            <styleClass>
                                <String fx:value="filter-input"/>
                            </styleClass>
                            <HBox.hgrow>
                                <Priority fx:value="ALWAYS"/>
                            </HBox.hgrow>
                        </TextField>
                        <ComboBox fx:id="roleFilter" promptText="All Roles">
                            <styleClass>
                                <String fx:value="combo-box"/>
                            </styleClass>
                        </ComboBox>
                        <ComboBox fx:id="statusFilter" promptText="All Statuses">
                            <styleClass>
                                <String fx:value="combo-box"/>
                            </styleClass>
                        </ComboBox>
                    </children>
                </HBox>

                <VBox>
                    <styleClass>
                        <String fx:value="card"/>
                    </styleClass>
                    <padding>
                        <Insets top="0.0" right="0.0" bottom="0.0" left="0.0"/>
                    </padding>
                    <children>
                        <TableView fx:id="usersTable" prefHeight="450.0">
                            <styleClass>
                                <String fx:value="table-view"/>
                            </styleClass>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="nameColumn" minWidth="160.0" text="Full Name"/>
                                <TableColumn fx:id="emailColumn" minWidth="180.0" text="Email"/>
                                <TableColumn fx:id="roleColumn" minWidth="100.0" text="Role"/>
                                <TableColumn fx:id="joinedColumn" minWidth="90.0" text="Joined"/>
                                <TableColumn fx:id="actionsColumn" minWidth="200.0" text="Actions"/>
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>

