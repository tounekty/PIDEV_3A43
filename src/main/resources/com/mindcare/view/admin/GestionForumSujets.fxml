<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mindcare.controller.admin.GestionForumSujetsController">

    <top>
        <VBox spacing="10.0" styleClass="card" BorderPane.alignment="CENTER_LEFT">
            <padding>
                <Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/>
            </padding>
            <Label text="Admin Ticket Management" styleClass="page-title"/>
            <Label text="Manage all support tickets and open details to handle messages" styleClass="page-subtitle"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="12.0">
            <padding>
                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
            </padding>

            <TableView fx:id="ticketTable" prefHeight="420.0">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="80.0"/>
                    <TableColumn fx:id="colSubject" text="Subject" prefWidth="260.0"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="140.0"/>
                    <TableColumn fx:id="colPriority" text="Priority" prefWidth="120.0"/>
                    <TableColumn fx:id="colCreatedAt" text="Created At" prefWidth="180.0"/>
                </columns>
            </TableView>

            <VBox spacing="8.0" styleClass="card">
                <padding>
                    <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                </padding>

                <Label text="Ticket Editor" styleClass="section-title"/>

                <HBox spacing="10.0">
                    <TextField fx:id="searchField" promptText="Search by id, subject, status, priority" HBox.hgrow="ALWAYS"/>
                    <ChoiceBox fx:id="sortChoice" prefWidth="190.0"/>
                </HBox>

                <ComboBox fx:id="userChoice" promptText="Select user" prefWidth="420.0"/>

                <ComboBox fx:id="categoryChoice" promptText="Select category" prefWidth="420.0"/>

                <TextField fx:id="subjectField" promptText="Subject"/>

                <HBox spacing="10.0">
                    <ChoiceBox fx:id="statusChoice" prefWidth="200.0"/>
                    <ChoiceBox fx:id="priorityChoice" prefWidth="200.0"/>
                </HBox>

                <TextArea fx:id="resolutionArea" promptText="Description / Resolution" prefRowCount="3"/>

                <HBox spacing="10.0">
                    <Button text="Add Ticket" onAction="#onAddTicket" styleClass="btn"/>
                    <Button text="Update Ticket" onAction="#onUpdateTicket" styleClass="btn"/>
                    <Button text="Delete Ticket" onAction="#onDeleteTicket" styleClass="btn"/>
                    <Button text="Open Ticket" onAction="#onOpenTicket" styleClass="btn"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>

