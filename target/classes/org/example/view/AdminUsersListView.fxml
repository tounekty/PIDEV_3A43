<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" spacing="25" styleClass="dashboard-card" style="-fx-background-color: white; -fx-padding: 35px; -fx-background-radius: 12px;">
    <stylesheets>
        <URL value="@mindcare-theme.css" />
    </stylesheets>

    <children>
        <!-- Header & Add Button -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="User Management" styleClass="title-text" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #111827;" />
                <Label text="Manage your platform members, roles, and access seamlessly." styleClass="subtitle-text" style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" />
            </VBox>
            <Button fx:id="adminUsersAddButton" text="+ Add New User" styleClass="btn-primary" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12px 24px; -fx-background-radius: 8px; -fx-cursor: hand;" />
        </HBox>

        <!-- Search & Filters -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="search-container" style="-fx-background-color: #f9fafb; -fx-padding: 15px; -fx-background-radius: 10px; -fx-border-color: #e5e7eb; -fx-border-radius: 10px;">
            <Label text="🔍" style="-fx-text-fill: #9ca3af; -fx-font-size: 16px;" />
            <TextField fx:id="adminUsersSearchField" promptText="Search users by name, email, or role..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #111827; -fx-font-size: 14px;" />
            <Button fx:id="adminUsersClearSearchButton" text="Clear" styleClass="btn-secondary" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 6px; -fx-padding: 8px 16px; -fx-text-fill: #374151; -fx-cursor: hand;" />
        </HBox>

        <!-- Table View -->
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="table-view" style="-fx-background-color: transparent; -fx-border-color: #e5e7eb; -fx-border-radius: 8px; -fx-border-width: 1px;">
            <columns>
                <TableColumn fx:id="usersIdCol" text="ID" prefWidth="60" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
                <TableColumn fx:id="usersEmailCol" text="Email Address" prefWidth="250" style="-fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 15px; -fx-text-fill: #6b7280;" />
                <TableColumn fx:id="usersRoleCol" text="Role" prefWidth="110" style="-fx-alignment: CENTER; -fx-font-weight: bold; -fx-text-fill: #6366f1;" />
                <TableColumn fx:id="usersStatusCol" text="Banned Until" prefWidth="150" style="-fx-alignment: CENTER; -fx-font-weight: bold;" />
                <TableColumn fx:id="usersActionsCol" text="Actions" prefWidth="320" style="-fx-alignment: CENTER;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10px 0 0 0;">
            <Button fx:id="adminUsersRefreshButton" text="↻ Refresh List" style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 8px; -fx-cursor: hand;" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <Label fx:id="adminUsersListErrorLabel" visible="false" managed="false" style="-fx-text-fill: #dc2626; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #fee2e2; -fx-padding: 10 16; -fx-background-radius: 8;" />
    </children>
</VBox>
