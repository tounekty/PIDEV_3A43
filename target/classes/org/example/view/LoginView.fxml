<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" style="-fx-background-color: #f3f4f6; -fx-padding: 40px;">
    <stylesheets>
        <URL value="@mindcare-theme.css" />
    </stylesheets>

    <children>
        <VBox spacing="20" maxWidth="450" alignment="CENTER" styleClass="dashboard-card" style="-fx-padding: 40px; -fx-background-color: white; -fx-background-radius: 16px;">
            <children>
                <Label text="MindCare" style="-fx-text-fill: #6366f1; -fx-font-size: 32px; -fx-font-weight: 900; -fx-font-family: 'Segoe UI', sans-serif;" />
                
                <VBox spacing="5" alignment="CENTER" style="-fx-padding: 0 0 15px 0;">
                    <Label text="Welcome back" styleClass="title-text" style="-fx-font-size: 24px;" />
                    <Label text="Sign in to your account to continue" styleClass="subtitle-text" />
                </VBox>

                <VBox spacing="10" maxWidth="Infinity">
                    <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <TextField fx:id="loginEmailField" promptText="Enter your email" styleClass="text-field" />
                </VBox>

                <VBox spacing="10" maxWidth="Infinity">
                    <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <PasswordField fx:id="loginPasswordField" promptText="Enter your password" styleClass="password-field" />
                </VBox>

                <Label fx:id="loginErrorLabel" visible="false" managed="false" styleClass="error-label" maxWidth="Infinity" alignment="CENTER" />


                <VBox spacing="15" maxWidth="Infinity" style="-fx-padding: 10px 0 0 0;">
                    <Button text="Sign In" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity" style="-fx-padding: 14px;" />
                    <Button text="Login with Face ID" onAction="#handleFaceLogin" styleClass="btn-primary" maxWidth="Infinity" style="-fx-padding: 14px; -fx-background-color: #10b981; -fx-border-color: #059669;" />
                    <Button text="Create an Account" onAction="#handleShowRegister" styleClass="btn-secondary" maxWidth="Infinity" style="-fx-padding: 14px; -fx-background-color: #f9fafb;" />
                    <Hyperlink text="Forgot password? click here" onAction="#handleForgotPassword" maxWidth="Infinity" style="-fx-text-fill: #2563eb; -fx-font-size: 13px; -fx-underline: true;" />
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
