<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" alignment="CENTER" style="-fx-background-color: #f3f4f6; -fx-padding: 40px;">
    <stylesheets>
        <URL value="@mindcare-theme.css" />
    </stylesheets>

    <children>
        <VBox spacing="18" maxWidth="450" alignment="CENTER" styleClass="dashboard-card" style="-fx-padding: 40px; -fx-background-color: white; -fx-background-radius: 16px;">
            <children>
                <Label text="MindCare" style="-fx-text-fill: #6366f1; -fx-font-size: 32px; -fx-font-weight: 900; -fx-font-family: 'Segoe UI', sans-serif;" />
                
                <VBox spacing="5" alignment="CENTER" style="-fx-padding: 0 0 10px 0;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button text="←" onAction="#handleShowLogin" style="-fx-background-color: transparent; -fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-cursor: hand;" />
                        <Label text="Create an Account" styleClass="title-text" style="-fx-font-size: 24px;" />
                    </HBox>
                    <Label text="Join MindCare and start your journey" styleClass="subtitle-text" />
                </VBox>

                <VBox spacing="8" maxWidth="Infinity">
                    <Label text="Email Address" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <TextField fx:id="registerEmailField" promptText="name@example.com" styleClass="text-field" />
                </VBox>

                <VBox spacing="8" maxWidth="Infinity">
                    <Label text="First Name" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <TextField fx:id="registerFirstNameField" promptText="Your first name" styleClass="text-field" />
                </VBox>

                <VBox spacing="8" maxWidth="Infinity">
                    <Label text="Last Name" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <TextField fx:id="registerLastNameField" promptText="Your last name" styleClass="text-field" />
                </VBox>

                <VBox spacing="8" maxWidth="Infinity">
                    <Label text="Password" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <PasswordField fx:id="registerPasswordField" promptText="Create a strong password" styleClass="password-field" />
                </VBox>

                <VBox spacing="8" maxWidth="Infinity">
                    <Label text="Confirm Password" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <PasswordField fx:id="registerConfirmPasswordField" promptText="Repeat your password" styleClass="password-field" />
                </VBox>

                <Label fx:id="registerErrorLabel" visible="false" managed="false" styleClass="error-label" maxWidth="Infinity" alignment="CENTER" />


                <VBox spacing="15" maxWidth="Infinity" style="-fx-padding: 15px 0 0 0;">
                    <Button text="Sign Up" onAction="#handleRegister" styleClass="btn-primary" maxWidth="Infinity" style="-fx-padding: 14px;" />
                    <Button text="Already have an account? Sign In" onAction="#handleShowLogin" styleClass="btn-secondary" maxWidth="Infinity" style="-fx-padding: 14px; -fx-background-color: #f9fafb;" />
                    <Button text="← Back to Login" onAction="#handleShowLogin" styleClass="btn-ghost" maxWidth="Infinity" />
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
